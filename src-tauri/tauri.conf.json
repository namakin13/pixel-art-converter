{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ドット絵コンバーター",
  "mainBinaryName": "pixel-art-converter",
  "version": "0.2.1",
  "identifier": "com.nofxy.pixel-art-converter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ドット絵コンバーター",
        "width": 1000,
        "height": 720,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "namakin13",
    "copyright": "© 2026 namakin13",
    "category": "GraphicsAndDesign",
    "shortDescription": "イラストをドット絵に変換",
    "longDescription": "イラストや写真をドット絵に変換し、編集・アイコン書き出しもできるツール。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Japanese", "English"],
        "installMode": "currentUser"
      }
    }
  }
}
